<!DOCTYPE html>
<html>
<body>
<form onsubmit="return validate()">
  Name: <input type="text" id="name"><br><br>
  Email: <input type="text" id="email"><br><br>
  <input type="submit">
</form>

<script>
function validate() {
  let name = document.getElementById("name").value;
  let email = document.getElementById("email").value;

  if (name == "") {
    alert("Name required");
    return false;
  }
  if (!email.includes("@")) {
    alert("Invalid email");
    return false;
  }
  return true;
}
</script>
</body>
</html>
