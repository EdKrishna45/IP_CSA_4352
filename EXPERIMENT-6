JAVA:-
import java.io.*;
import javax.servlet.*;
import javax.servlet.http.*;

public class ExamServlet extends HttpServlet {
  protected void doPost(HttpServletRequest req, HttpServletResponse res)
  throws IOException {
    int score = 0;

    if ("A".equals(req.getParameter("q1"))) score++;
    if ("B".equals(req.getParameter("q2"))) score++;

    res.getWriter().println("Score: " + score);
  }
}

HTML:-
<form action="ExamServlet" method="post">
  Q1: <input type="radio" name="q1" value="A">A
      <input type="radio" name="q1" value="B">B<br>

  Q2: <input type="radio" name="q2" value="A">A
      <input type="radio" name="q2" value="B">B<br>

  <input type="submit">
</form>
