<!DOCTYPE html>
<html>
<head>
    <title>Frameset Example</title>
</head>

<frameset cols="30%,70%">
    
    <frame src="left.html" name="leftframe">
    
    <frame src="right.html" name="rightframe">

</frameset>

</html>


<!DOCTYPE html>
<html>
<body>

<h2>Left Frame</h2>
<p>This is the left frame.</p>

</body>
</html>


<!DOCTYPE html>
<html>
<body>

<h2>Right Frame</h2>
<p>This is the right frame.</p>

</body>
</html>
